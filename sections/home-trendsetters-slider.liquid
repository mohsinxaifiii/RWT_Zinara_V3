<div class="section-{{ section.id }}">
  <div class="page-width">
    <div class="swiper trend-carousel-{{ section.id }}">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.url }}">
              <img src="{{ block.settings.image | image_url: width: 800 }}">
              <div class="carousel-label">
                {{ block.settings.text }}
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      <div class="swiper-pagination"></div>
    </div>
  </div>
</div>
{% stylesheet %}
  .section-{{ section.id }} {
    padding: 60px 0;
    background: #f4f4f4;
  }

  .swiper {
    overflow: visible;
  }

  .swiper-slide {
    transition: transform 0.4s ease, opacity 0.4s ease;
    opacity: 0.4;
    transform: scale(0.85);
  }

  .swiper-slide-active {
    opacity: 1;
    transform: scale(1);
  }

  .swiper-slide-prev,
  .swiper-slide-next {
    opacity: 0.6;
    transform: scale(0.9);
  }

  .swiper-slide img {
    width: 100%;
    border-radius: 8px;
    display: block;
  }

  .carousel-label {
    position: absolute;
    bottom: 12px;
    left: 12px;
    background: rgba(0,0,0,0.6);
    color: #fff;
    font-size: 12px;
    padding: 6px 10px;
    border-radius: 4px;
  }

  /* dots */
  .swiper-pagination {
    margin-top: 20px;
    position: relative;
  }

  .swiper-pagination-bullet {
    background: #bbb;
    opacity: 1;
    transition: all 0.3s ease;
  }

  .swiper-pagination-bullet-active {
    width: 28px;
    border-radius: 10px;
    background: #000;
  }
{% endstylesheet %}
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.trend-carousel-{{ section.id }}', {
      loop: true,
      centeredSlides: true,
      grabCursor: true,

      autoplay: {
        delay: 4000,
        disableOnInteraction: false,
      },

      speed: 600,

      slidesPerView: 5,
      spaceBetween: 20,

      breakpoints: {
        0: {
          slidesPerView: 1.2, // center + side peek
          spaceBetween: 10,
        },
        768: {
          slidesPerView: 5,
          spaceBetween: 20,
        },
      },

      pagination: {
        el: '.trend-carousel-{{ section.id }} .swiper-pagination',
        clickable: true,
      },
    });
  });
</script>
{% schema %}
{
  "name": "Trendsetters Carousel",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Label",
          "default": "Daily Wear"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trendsetters Carousel"
    }
  ]
}
{% endschema %}
