<div class="section-{{ section.id }}">
  <div class="carousel-wrapper" id="carousel-{{ section.id }}">
    <div class="carousel-track">
      {% for block in section.blocks %}
        <div class="carousel-slide" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.url }}">
            <img src="{{ block.settings.image | image_url: width: 800 }}">
            <div class="carousel-label">
              {{ block.settings.text }}
            </div>
          </a>
        </div>
      {% endfor %}
    </div>

    <div class="carousel-dots"></div>
  </div>
</div>
{% stylesheet %}
  .section-{{ section.id }} {
    background: #f4f4f4;
    padding: 60px 0;
    overflow: hidden;
  }

  .carousel-wrapper {
    position: relative;
    max-width: 900px;
    margin: auto;
  }

  .carousel-track {
    display: flex;
    align-items: center;
    transition: transform 0.5s ease;
    will-change: transform;
  }

  .carousel-slide {
    flex: 0 0 60%;
    padding: 0 10px;
    transition: transform 0.4s ease, opacity 0.4s ease;
    opacity: 0.4;
    transform: scale(0.85);
  }

  .carousel-slide.is-active {
    opacity: 1;
    transform: scale(1);
  }

  .carousel-slide.is-prev,
  .carousel-slide.is-next {
    opacity: 0.6;
    transform: scale(0.9);
  }

  .carousel-slide a {
    display: block;
    position: relative;
  }

  .carousel-slide img {
    width: 100%;
    border-radius: 6px;
    display: block;
  }

  .carousel-label {
    position: absolute;
    bottom: 12px;
    left: 12px;
    background: rgba(0,0,0,0.6);
    color: #fff;
    font-size: 12px;
    padding: 6px 10px;
    border-radius: 3px;
  }

  /* DOTS */

  .carousel-dots {
    margin-top: 20px;
    display: flex;
    justify-content: center;
    gap: 8px;
  }

  .carousel-dot {
    height: 6px;
    width: 6px;
    background: #bbb;
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    transition: all 0.3s ease;
  }

  .carousel-dot.active {
    width: 28px;
    background: #ddd;
  }

  .carousel-dot.active::after {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0%;
    background: #000;
    animation: dotProgress 4s linear forwards;
  }

  @keyframes dotProgress {
    from { width: 0%; }
    to { width: 100%; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const root = document.getElementById('carousel-{{ section.id }}');
    const track = root.querySelector('.carousel-track');
    const dotsContainer = root.querySelector('.carousel-dots');

    let slides = Array.from(track.children);
    let index = 1;
    let autoTimer;
    const SLIDE_TIME = 4000;

    // CLONE (infinite loop)
    const first = slides[0].cloneNode(true);
    const last = slides[slides.length - 1].cloneNode(true);

    track.appendChild(first);
    track.insertBefore(last, slides[0]);

    slides = Array.from(track.children);

    function getSlideWidth() {
      return slides[0].getBoundingClientRect().width;
    }

    function setPosition(animate = true) {
      const width = getSlideWidth();
      track.style.transition = animate ? 'transform 0.5s ease' : 'none';
      track.style.transform = `translateX(-${index * width}px)`;
      updateClasses();
      updateDots();
    }

    function updateClasses() {
      slides.forEach((s) => s.classList.remove('is-active', 'is-prev', 'is-next'));

      slides[index]?.classList.add('is-active');
      slides[index - 1]?.classList.add('is-prev');
      slides[index + 1]?.classList.add('is-next');
    }

    function buildDots() {
      dotsContainer.innerHTML = '';
      for (let i = 0; i < slides.length - 2; i++) {
        const dot = document.createElement('div');
        dot.className = 'carousel-dot';
        dotsContainer.appendChild(dot);
      }
    }

    function updateDots() {
      const dots = dotsContainer.children;
      const realIndex = (index - 1 + dots.length) % dots.length;

      [...dots].forEach((d) => d.classList.remove('active'));
      dots[realIndex]?.classList.add('active');
    }

    function next() {
      index++;
      setPosition();

      if (index === slides.length - 1) {
        setTimeout(() => {
          index = 1;
          setPosition(false);
        }, 500);
      }
    }

    function prev() {
      index--;
      setPosition();

      if (index === 0) {
        setTimeout(() => {
          index = slides.length - 2;
          setPosition(false);
        }, 500);
      }
    }

    function autoPlay() {
      clearInterval(autoTimer);
      autoTimer = setInterval(next, SLIDE_TIME);
    }

    // DRAG
    let startX = 0;
    let isDown = false;
    let current = 0;
    let prevTranslate = 0;

    function getX(e) {
      return e.touches ? e.touches[0].clientX : e.pageX;
    }

    function dragStart(e) {
      isDown = true;
      startX = getX(e);
      prevTranslate = -index * getSlideWidth();
      track.style.transition = 'none';
    }

    function dragMove(e) {
      if (!isDown) return;
      const diff = getX(e) - startX;
      current = prevTranslate + diff;
      track.style.transform = `translateX(${current}px)`;
    }

    function dragEnd() {
      if (!isDown) return;
      isDown = false;

      const moved = current - prevTranslate;

      if (moved < -50) next();
      else if (moved > 50) prev();
      else setPosition();

      autoPlay();
    }

    track.addEventListener('mousedown', dragStart);
    track.addEventListener('touchstart', dragStart);

    window.addEventListener('mousemove', dragMove);
    window.addEventListener('touchmove', dragMove);

    window.addEventListener('mouseup', dragEnd);
    window.addEventListener('touchend', dragEnd);

    // FIX: wait for images to load before init
    function initWhenReady() {
      const imgs = track.querySelectorAll('img');
      let loaded = 0;

      imgs.forEach((img) => {
        if (img.complete) loaded++;
        else {
          img.onload = () => {
            loaded++;
            if (loaded === imgs.length) init();
          };
        }
      });

      if (loaded === imgs.length) init();
    }

    function init() {
      buildDots();
      setPosition(false);
      autoPlay();
    }

    // also fix resize glitch
    window.addEventListener('resize', () => {
      setPosition(false);
    });

    initWhenReady();
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Trendsetters Carousel",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Label",
          "default": "Daily Wear"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trendsetters Carousel"
    }
  ]
}
{% endschema %}
