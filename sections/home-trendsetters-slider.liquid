<div class="section-{{ section.id }}">
  <div class="page-width">
    <div class="swiper trend-carousel-{{ section.id }}">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.url }}">
              <img src="{{ block.settings.image | image_url: width: 800 }}">
              <div class="carousel-label">
                {{ block.settings.text }}
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    </div>
    <div class="swiper-pagination trend-pagination-{{ section.id }}"></div>
  </div>
</div>
{% stylesheet %}
      .swiper {
        overflow: visible;
      }

      .swiper-wrapper {
        align-items: center;
      }

      .swiper-slide {
        height: auto;
      }
        .section-{{ section.id }} {
          padding: 60px 0;
          background: #f4f4f4;
        }

        .swiper {
          overflow: visible;
        }

  .swiper-slide {
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
                opacity 0.5s ease,
                filter 0.5s ease;

    opacity: 0.35;
    transform: scale(0.8);
    filter: blur(1px);
  }

  /* ACTIVE */
  .swiper-slide-active {
    opacity: 1;
    transform: scale(1);
    filter: blur(0);
    z-index: 2;
  }

  /* SIDE */
  .swiper-slide-prev,
  .swiper-slide-next {
    opacity: 0.6;
    transform: scale(0.9);
    filter: blur(0.5px);
    z-index: 1;
  }

        .swiper-slide img {
          width: 100%;
          border-radius: 8px;
          display: block;
        }

        .carousel-label {
          position: absolute;
          bottom: 12px;
          left: 12px;
          background: rgba(0,0,0,0.6);
          color: #fff;
          font-size: 12px;
          padding: 6px 10px;
          border-radius: 4px;
        }

        /* dots */
        .swiper-pagination {
          margin-top: 20px;
          position: relative;
        }

    /* DOT BASE */
    .swiper-pagination-bullet {
      width: 8px;
      height: 6px;
      background: #bbb;
      border-radius: 10px;
      position: relative;
      overflow: hidden;
      transition: all 0.3s ease;
    }

    /* ACTIVE DOT */
    .swiper-pagination-bullet-active {
      background: #D1D5DC;
          width: 50px;
    border-radius: 30px;
    }

    /* PROGRESS BAR */
    .swiper-pagination-bullet-active::after {
      content: "";
      position: absolute;
      left: 0;
      top: 0;
      height: 100%;
      width: 0%;
      background: #1A1A1A;
      animation: dotProgress 4s linear forwards;
    }

    @keyframes dotProgress {
      from { width: 0%; }
      to { width: 100%; }
    }
{% endstylesheet %}
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.trend-carousel-{{ section.id }}', {
      loop: true,
      centeredSlides: true,
      grabCursor: true,

      autoplay: {
        delay: 4000,
        disableOnInteraction: false,
      },

      speed: 600,

      slidesPerView: 5,
      spaceBetween: 20,

      breakpoints: {
        0: {
          slidesPerView: 1.2, // center + side peek
          spaceBetween: 10,
        },
        768: {
          slidesPerView: 5,
          spaceBetween: 20,
        },
      },

      pagination: {
        el: '.trend-carousel-{{ section.id }} .swiper-pagination',
        clickable: true,
      },

      on: {
        slideChange: function () {
          const bullets = document.querySelectorAll('.trend-carousel-{{ section.id }} .swiper-pagination-bullet');

          bullets.forEach((b) => {
            b.style.animation = 'none';
            b.offsetHeight; // force reflow
            b.style.animation = null;
          });
        },
      },
    });
  });
</script>
{% schema %}
{
  "name": "Trendsetters Carousel",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Label",
          "default": "Daily Wear"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trendsetters Carousel"
    }
  ]
}
{% endschema %}
