<div class="home-zinara-collections__container">
  <h2>{{ section.settings.heading }}</h2>
  {% for block in section.blocks %}
    <div class="zinara-collection_container">
      <a href="{{ block.settings.collection_link }}" class="zinara-collection_link">
        <img
          src="{{ block.settings.collection_image | img_url }}"
          alt="{{ block.settings.collection_title }}"
          class="zinara-collection_image"
        >
        <h3 class="zinara-collection_title">{{ block.settings.collection_title }}</h3>
      </a>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Home Zinara Collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Zinara Collections"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "text",
          "id": "collection_title",
          "label": "Collection Title"
        },
        {
          "type": "url",
          "id": "collection_link",
          "label": "Collection Link"
        },
        {
          "type": "image_picker",
          "id": "collection_image",
          "label": "Collection Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Zinara Collections"
    }
  ]
}
{% endschema %}
