<script>
  (function () {
    document.addEventListener('DOMContentLoaded', function () {
      console.log('add_to_cart DOM fully loaded');

      // Find all forms that have a button with class product-form__submit
      const productForms = Array.from(document.querySelectorAll('form')).filter((form) =>
        form.querySelector('button.product-form__submit')
      );

      if (productForms.length === 0) {
        console.error('❌ No product forms with .product-form__submit button found!');
        return;
      }

      console.log(`add_to_cart ✅ Found ${productForms.length} product form(s)`);

      productForms.forEach((productForm) => {
        let triggered = false;

        productForm.addEventListener('submit', function (event) {
          if (triggered) {
            console.warn('⚠️ Add to cart event already triggered, ignoring duplicate');
            return;
          }
          triggered = true;

          setTimeout(() => (triggered = false), 2000);

          const variantInput = productForm.querySelector('.product-variant-id');
          if (!variantInput) {
            console.error('❌ Variant ID input (.product-variant-id) NOT found in this form!');
            return;
          }
          const variantId = variantInput.value;
          console.log('add_to_cart Variant ID:', variantId);

          // Check window.product presence
          if (typeof window.product === 'undefined') {
            console.error('❌ window.product is undefined. Make sure product JSON is available globally.');
            return;
          }

          const productData = window.product;
          console.log('add_to_cart Product data:', productData);

          if (!productData.variants || productData.variants.length === 0) {
            console.error('❌ productData.variants missing or empty');
            return;
          }

          const variant = productData.variants.find((v) => v.id == variantId);
          if (!variant) {
            console.warn('⚠️ Variant not found in productData.variants, using first available variant');
          }
          const selectedVariant = variant || productData.variants[0];
          console.log('add_to_cart Selected variant:', selectedVariant);

          const customer = window.customer || {};
          const addr = customer.default_address || {};
          const address = [addr.address1, addr.address2, addr.city, addr.province, addr.country, addr.zip]
            .filter(Boolean)
            .join(', ');

          const eventData = {
            event: 'add_to_cart',
            product_id: productData.id,
            product_title: productData.title,
            variant_id: selectedVariant.id,
            variant_title: selectedVariant.title,
            sku: selectedVariant.sku,
            price: selectedVariant.price / 100,
            quantity: 1,
            customer: {
              id: customer.id || null,
              email: customer.email || null,
              name: addr.name || `${customer.first_name || ''} ${customer.last_name || ''}`.trim() || null,
              phone: customer.phone || addr.phone || null,
              address: address || null,
            },
            page_url: window.location.href,
            page_title: document.title,
          };

          console.log('add_to_cart Event data:', eventData);

          if (typeof gtag === 'function') {
            gtag('event', 'add_to_cart', eventData);
            console.log('add_to_cart GA event sent');
          } else {
            console.warn('⚠️ gtag function not found, skipping analytics event');
          }

          // ✅ Meta Pixel tracking
          if (typeof fbq === 'function') {
            fbq('trackCustom', 'add_to_cart', eventData);
            console.log('add_to_cart Meta Pixel event sent');
          } else {
            console.warn('⚠️ fbq function not found, skipping Meta event');
          }
        });
      });
    });
  })();
</script>

<script>
  (function () {
    document.addEventListener('DOMContentLoaded', function () {
      const submitBtn = document.getElementById('tryAtHomeSubmitBtn');
      const pincodeInput = document.getElementById('tryAtHomeZipcode');
      const resultDiv = document.getElementById('tryAtHomeRes');

      if (!submitBtn || !pincodeInput || !resultDiv) {
        console.warn('TryAtHome elements not found.');
        return;
      }

      submitBtn.addEventListener('click', function (event) {
        event.preventDefault(); // Prevent form submission or default behavior

        const pincode = pincodeInput.value.trim();
        const result = resultDiv.textContent.trim();
        const pageUrl = window.location.href;

        // Product and customer data (make sure these are set globally like in add_to_cart)
        const productData = window.product || null;
        const customerData = window.customer || {};

        const eventData = {
          event: 'check_availability_tryathome',
          pincode: pincode,
          result: result,
          page_url: pageUrl,
          product_id: productData?.id || null,
          product_title: productData?.title || '',
          product_type: productData?.type || '',
          variant_id: productData?.selected_or_first_available_variant?.id || null,
          variant_title: productData?.selected_or_first_available_variant?.title || '',
          customer_id: customerData.id || null,
          customer_email: customerData.email || '',
          customer_name:
            (customerData.default_address && customerData.default_address.name) ||
            `${customerData.first_name || ''} ${customerData.last_name || ''}`.trim(),
          customer_phone:
            customerData.phone || (customerData.default_address && customerData.default_address.phone) || '',
          customer_address: customerData.default_address
            ? [
                customerData.default_address.address1,
                customerData.default_address.address2,
                customerData.default_address.city,
                customerData.default_address.province,
                customerData.default_address.country,
                customerData.default_address.zip,
              ]
                .filter(Boolean)
                .join(', ')
            : '',
        };

        console.log('check_availability_tryathome event data:', eventData);

        // ✅ gtag event
        if (typeof gtag === 'function') {
          gtag('event', 'check_availability_tryathome', eventData);
        } else {
          console.warn('gtag not found, event not sent');
        }

        // ✅ Meta Pixel event
        if (typeof fbq === 'function') {
          fbq('trackCustom', 'check_availability_tryathome', eventData);
          console.log('check_availability_tryathome Meta Pixel event sent');
        } else {
          console.warn('fbq not found, Meta Pixel event not sent');
        }

        // If you want to proceed with the redirect or other default logic, do it here
        // e.g., window.location.href = someUrl;
      });
    });
  })();
</script>

