              {%- when 'pincode-availability' -%}
                <div class="pincode-availability-checker-container">
                  <div class="pincode-availability-left">
                    {% comment %} <img src="https://cdn.shopify.com/s/files/1/0661/8336/4792/files/Location_1.png?v=1744183003"> {% endcomment %}
                    <input
                      id="zipcode"
                      type="number"
                      class="pincode-checker-input"
                      placeholder="Enter Pincode"
                      maxlength="6"
                    >
                  </div>
                  <button id="submit-btn" type="submit" class="pincode-checker-button">Check Availability</button>
                </div>

                <div id="res" class="pincode-checker-result"></div>

                <p class="expected-delivery-date" style="display: none;">
                  Get it delivered by: <span id="delivery-date"></span>
                </p>

                <script>
                  (function () {
                    function initPincodeChecker() {
                    const btn = document.getElementById('submit-btn');
                    const zipcodeInput = document.getElementById('zipcode');
                    const res = document.getElementById('res');
                    const deliveryDateSpan = document.getElementById('delivery-date');
                    const deliveryDateParagraph = document.querySelector('.expected-delivery-date');

                    let validPincodesGold = new Set();
                    let validPincodesSilver = new Set();

                    // ✅ Load pincodes.json
                    fetch('{{ "pincodes.json" | asset_url }}')
                      .then((res) => res.json())
                      .then((data) => {
                        validPincodesGold = new Set(data.gold || []);
                        validPincodesSilver = new Set(data.silver || []);
                        console.log('Pincode data loaded');
                      })
                      .catch((err) => console.error('Pincode JSON load failed:', err));

                    // ✅ Variant handling (FIXED)
                    let currentVariant = null;

                    // initial variant
                    const variantJson = document.querySelector('[data-selected-variant]');
                    if (variantJson) {
                      currentVariant = JSON.parse(variantJson.textContent);
                    }

                    // update on variant change
                    document.addEventListener('change', () => {
                      const variantId = document.querySelector('[name="id"]')?.value;
                      if (!variantId) return;

                      const allVariants = {{ product.variants | json }};
                      const found = allVariants.find(v => v.id == variantId);

                      if (found) {
                        currentVariant = found;
                        console.log('Updated variant:', currentVariant.option1);
                      }
                    });

                    // ✅ Correct dataset selection
                    function getCurrentSet() {
                      const option1 = currentVariant?.option1?.toLowerCase() || '';

                      console.log('OPTION1:', option1);

                      if (option1.includes('gold') && !option1.includes('vermeil')) {
                        return validPincodesGold;
                      }

                      if (option1.includes('vermeil') || option1.includes('silver')) {
                        return validPincodesSilver;
                      }

                      return validPincodesGold;
                    }

                    // ✅ Delivery date (constant 3 days)
                    function getDeliveryDate() {
                      const today = new Date();
                      today.setDate(today.getDate() + 3);

                      return today.toLocaleDateString('en-US', {
                        day: 'numeric',
                        month: 'long',
                        year: 'numeric',
                      });
                    }

                    // ✅ Only allow numbers
                    zipcodeInput.addEventListener('input', (e) => {
                      e.target.value = e.target.value.replace(/[^0-9]/g, '');
                    });

                    // ✅ MAIN CLICK
                    btn.addEventListener('click', () => {
                      if (validPincodesGold.size === 0 && validPincodesSilver.size === 0) {
                        res.textContent = 'Loading... try again';
                        return;
                      }

                      const zipcode = zipcodeInput.value.trim();
                      const regex = /^[1-9][0-9]{5}$/;

                      res.textContent = '';
                      res.className = 'pincode-checker-result';

                      if (!regex.test(zipcode)) {
                        res.textContent = 'Invalid Pincode';
                        res.className = 'pincode-checker-result invalid';
                        deliveryDateParagraph.style.display = 'none';
                        return;
                      }

                      const currentSet = getCurrentSet();

                      console.log('Entered:', zipcode);
                      console.log('Using gold:', currentSet === validPincodesGold);
                      console.log('Using silver:', currentSet === validPincodesSilver);
                      console.log('Exists:', currentSet.has(zipcode));

                      if (!currentSet.has(zipcode)) {
                        res.textContent = 'Pincode not serviceable';
                        res.className = 'pincode-checker-result invalid';
                        deliveryDateParagraph.style.display = 'none';
                        return;
                      }

                      const finalDate = getDeliveryDate();

                      res.textContent = 'Available';
                      res.className = 'pincode-checker-result available';
                      deliveryDateSpan.textContent = finalDate;
                      deliveryDateParagraph.style.display = 'block';
                    });
                    }
                    if (document.readyState === 'loading') {
                      document.addEventListener('DOMContentLoaded', initPincodeChecker);
                    } else {
                      initPincodeChecker();
                    }
                  })();
                </script>
                <script>
                  (function () {
                    function initPincodeGA() {
                    const checkerButton = document.querySelector('.pincode-checker-button');

                    function isElementVisible(el) {
                      return el && window.getComputedStyle(el).display !== 'none';
                    }

                    function sendPincodeAvailabilityEvent() {
                      const zipcode = document.getElementById('zipcode')?.value.trim();
                      const result = document.getElementById('res')?.innerText.trim();
                      const deliveryDateEl = document.querySelector('.expected-delivery-date');
                      const deliveryDate = document.getElementById('delivery-date')?.innerText.trim();

                      const customer = window.customer || {};
                      const address = customer.default_address || {};

                      const eventData = {
                        source_url: window.location.href,
                        page_title: document.title,
                        customer_id: customer.id || null,
                        customer_email: customer.email || null,
                        customer_name: `${customer.first_name || ''} ${customer.last_name || ''}`.trim(),
                        customer_phone: customer.phone || null,
                        customer_address: `${address.address1 || ''}, ${address.city || ''}, ${
                          address.province || ''
                        }, ${address.zip || ''}, ${address.country || ''}`.trim(),
                        pincode_entered: zipcode || null,
                        availability_result: result || null,
                      };

                      if (isElementVisible(deliveryDateEl)) {
                        eventData.expected_delivery_date = deliveryDate || null;
                      }

                      gtag('event', 'check_availability_ship', eventData);
                      console.log('check_availability_ship event sent with:', eventData);

                      // ✅ Meta Pixel tracking
                      if (typeof fbq === 'function') {
                        fbq('trackCustom', 'check_availability_ship', eventData);
                      }
                    }

                    checkerButton?.addEventListener('click', () => {
                      setTimeout(sendPincodeAvailabilityEvent, 500); // Allow time for DOM to update
                    });
                    }
                    if (document.readyState === 'loading') {
                      document.addEventListener('DOMContentLoaded', initPincodeGA);
                    } else {
                      initPincodeGA();
                    }
                  })();
                </script>

