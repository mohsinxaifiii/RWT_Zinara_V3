<script>
document.addEventListener('DOMContentLoaded', () => {

  const overlay = document.getElementById('tryAtHomeOverlay');
  const pincodePopup = document.getElementById('tryAtHomePincodePopup');
  const closeButton = document.getElementById('tryAtHomeClose');
  const submitButton_2 = document.getElementById('tryAtHomeSubmitBtn');
  const zipcodeInput = document.getElementById('tryAtHomeZipcode');
  const res = document.getElementById('tryAtHomeRes');
  const inventoryElement = document.querySelector('.product__inventory');
  const productFormButtons = document.querySelector('.product-form__buttons');

  // ✅ DATA (from JSON)
  let validPincodesGold = new Set();
  let validPincodesSilver = new Set();
  let validPincodes = new Set();

  // ✅ Load JSON
  fetch('{{ "pincodes.json" | asset_url }}')
    .then(res => res.json())
    .then(data => {
      validPincodesGold = new Set(data.gold || []);
      validPincodesSilver = new Set(data.silver || []);

      // assign based on product tag
      {% if product.tags contains 'gold' %}
        validPincodes = validPincodesGold;
      {% elsif product.tags contains 'vermeil' %}
        validPincodes = validPincodesSilver;
      {% else %}
        validPincodes = validPincodesGold;
      {% endif %}
    })
    .catch(err => console.error('Pincode JSON load failed:', err));

  let lastClickedButton = null;

  function isLoggedIn() {
    return {% if customer %}true{% else %}false{% endif %};
  }

  function handleDirectRedirect(zipcode) {
    const tryAtHomeUrl = `/pages/try-at-home?view=try-at-home&product_handle={{ product.handle }}`;
    const videoTrialUrl = `/pages/video-trial?view=video-trial&product_handle={{ product.handle }}`;

    if (!isLoggedIn()) {
      const targetUrl = validPincodes.has(zipcode) ? tryAtHomeUrl : videoTrialUrl;
      const loginUrl = `/account/login?return_url=${encodeURIComponent(targetUrl)}&kp_login=true&kp_redirect=${encodeURIComponent(targetUrl)}`;
      window.location.href = loginUrl;
      return;
    }

    if (validPincodes.has(zipcode)) {
      res.textContent = 'Available';
      res.className = 'try-at-home-pincode-result available';
      window.location.href = tryAtHomeUrl;
    } else {
      res.textContent = 'Pincode Not Available';
      res.className = 'try-at-home-pincode-result unavailable';
      window.location.href = videoTrialUrl;
    }
  }

  function showTrialButtons(zipcode) {
    const buttonsContainer = document.getElementById('tryAtHomeButtons');
    const homeTrialBtn = document.getElementById('homeTrialBtn');

    if (validPincodes.has(zipcode)) {
      res.textContent = 'Available - Choose your trial option';
      res.className = 'try-at-home-pincode-result available';
      homeTrialBtn.style.display = 'block';
      buttonsContainer.style.display = 'flex';
    } else {
      res.textContent = 'Pincode Not Available - Video Trial Only';
      res.className = 'try-at-home-pincode-result unavailable';
      homeTrialBtn.style.display = 'none';
      buttonsContainer.style.display = 'flex';
    }
  }

  function handleTrialButtonClicks() {
    const videoTrialBtn = document.getElementById('videoTrialBtn');
    const homeTrialBtn = document.getElementById('homeTrialBtn');

    const tryAtHomeUrl = `/pages/try-at-home?view=try-at-home&product_handle={{ product.handle }}`;
    const videoTrialUrl = `/pages/video-trial?view=video-trial&product_handle={{ product.handle }}`;

    videoTrialBtn.addEventListener('click', () => {
      if (!isLoggedIn()) {
        const loginUrl = `/account/login?return_url=${encodeURIComponent(videoTrialUrl)}&kp_login=true&kp_redirect=${encodeURIComponent(videoTrialUrl)}`;
        window.location.href = loginUrl;
      } else {
        window.location.href = videoTrialUrl;
      }
    });

    homeTrialBtn.addEventListener('click', () => {
      if (!isLoggedIn()) {
        const loginUrl = `/account/login?return_url=${encodeURIComponent(tryAtHomeUrl)}&kp_login=true&kp_redirect=${encodeURIComponent(tryAtHomeUrl)}`;
        window.location.href = loginUrl;
      } else {
        window.location.href = tryAtHomeUrl;
      }
    });
  }

  function togglePopup(buttonId) {
    document.getElementById(buttonId).addEventListener('click', () => {
      const globalPin = window.globalTryAtHomePincode;
      const regex = /^[1-9][0-9]{5}$/;

      if (globalPin && regex.test(globalPin)) {
        zipcodeInput.value = globalPin;
        localStorage.setItem('user_tryathomepincode', globalPin);

        overlay.style.display = 'flex';
        showTrialButtons(globalPin);
      } else {
        overlay.style.display = 'flex';
        lastClickedButton = buttonId;
      }
    });

    closeButton.addEventListener('click', () => {
      overlay.style.display = 'none';
      zipcodeInput.value = '';
      res.textContent = '';
      res.className = 'try-at-home-pincode-result';
      document.getElementById('tryAtHomeButtons').style.display = 'none';
      document.getElementById('homeTrialBtn').style.display = 'block';
    });

    overlay.addEventListener('click', (e) => {
      if (!pincodePopup.contains(e.target)) {
        overlay.style.display = 'none';
        zipcodeInput.value = '';
        res.textContent = '';
        res.className = 'try-at-home-pincode-result';
        document.getElementById('tryAtHomeButtons').style.display = 'none';
        document.getElementById('homeTrialBtn').style.display = 'block';
      }
    });
  }

  function handlePincodeCheck() {
    submitButton_2.addEventListener('click', () => {
      const zipcode = zipcodeInput.value.trim();
      const regex = /^[1-9][0-9]{5}$/;

      if (!regex.test(zipcode)) {
        res.textContent = 'Invalid Pincode';
        res.className = 'try-at-home-pincode-result invalid';
        return;
      }

      localStorage.setItem('user_tryathomepincode', zipcode);
      showTrialButtons(zipcode);
    });
  }

  zipcodeInput.addEventListener('input', (e) => {
    e.target.value = e.target.value.replace(/[^0-9]/g, '');
  });

  function updateButtonVisibility(buttonId) {
    const button = document.getElementById(buttonId);
    if (inventoryElement && button) {
      const inventoryText = inventoryElement.textContent.trim().toLowerCase();
    }
  }

  function moveButton(buttonId) {
    const button = document.getElementById(buttonId);
    if (window.innerWidth > 756 && button && productFormButtons) {
      productFormButtons.insertAdjacentElement('beforeend', button);
    }
  }

  function observeInventoryChanges(buttonId) {
    const observer = new MutationObserver(() => {
      updateButtonVisibility(buttonId);
    });
    if (inventoryElement) {
      observer.observe(inventoryElement, { childList: true, subtree: true });
    }
  }

  function initializeButton(buttonId) {
    togglePopup(buttonId);
    updateButtonVisibility(buttonId);
    observeInventoryChanges(buttonId);

    const intervalId = setInterval(() => moveButton(buttonId), 100);
    window.addEventListener('resize', () => {
      if (window.innerWidth > 756) {
        moveButton(buttonId);
      }
    });

    setTimeout(() => clearInterval(intervalId), 3000);
  }

  initializeButton('tryAtHomeButton');
  handlePincodeCheck();
  handleTrialButtonClicks();

});
</script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const submitBtn = document.getElementById('tryAtHomeSubmitBtn');

    if (submitBtn) {
      submitBtn.addEventListener('click', function () {
        const sourceUrl = window.location.href;
        const pincode = document.getElementById('tryAtHomeZipcode')?.value?.trim() || 'Unknown';

        // Get product handle and variant ID
        const urlParts = window.location.pathname.split('/');
        const productHandle = urlParts.includes('products') ? urlParts[urlParts.indexOf('products') + 1] : 'Unknown';
        const variantId = new URLSearchParams(window.location.search).get('variant') || 'Unknown';

        // Get selected variants
        const variantData = [];
        document.querySelectorAll('variant-selects .product-form__input').forEach(inputBlock => {
          const select = inputBlock.querySelector('select');
          if (select) {
            const name = select.getAttribute('name')?.replace('options[', '')?.replace(']', '');
            const value = select.value;
            if (name && value) {
              variantData.push({ [name]: value });
            }
          }
        });

        // Customer info from global object
        const customer = window.customer || {};
        const address = customer.default_address || {};

        const eventData = {
          source: 'PDP Popup',
          source_url: sourceUrl,
          redirect_url: sourceUrl,
          pincode: pincode,
          product_handle: productHandle,
          variant_id: variantId,
          tags: {{ product.tags | json }},
          category: {{ product.type | json }},
          price: {{ product.price | divided_by: 100.0 }},
          compare_at_price: {{ product.compare_at_price | divided_by: 100.0 }},
          feature_badges: [
            {% for badge in product.metafields.content['product-features-badges'].value %}
              "{{ badge }}"{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ],
          selected_variants: variantData.map(variant => {
            const key = Object.keys(variant)[0];
            return `${key}: ${variant[key]}`;
          }),
          customer_id: customer.id || null,
          customer_email: customer.email || null,
          customer_name: `${customer.first_name || ''} ${customer.last_name || ''}`.trim(),
          customer_phone: customer.phone || null,
          customer_address: `${address.address1 || ''}, ${address.city || ''}, ${address.province || ''}, ${address.zip || ''}, ${address.country || ''}`.trim()
        };

        gtag('event', 'try_at_home', eventData);

        // ✅ Meta Pixel: fire same event
        if (typeof fbq === 'function') {
          fbq('trackCustom', 'try_at_home', eventData);
        }

        console.log('try_at_home event fired:', eventData);
      });
    }
  });
</script>

