<link rel="stylesheet" href="{{ 'home-zinara-collections.css' | asset_url }}">
<div class="page-width home-zinara-collections__container">
  <h2>{{ section.settings.heading }}</h2>
  <div class="zinara-collection_container">
    {% for block in section.blocks %}
      <a href="{{ block.settings.collection_link }}" class="zinara-collection_link">
        <img
          style="border: solid 3px {{ block.settings.collection_border_color }};"
          src="{{ block.settings.collection_desktop_image | img_url }}"
          alt="{{ block.settings.collection_title }}"
          class="zinara-collection_image"
        >
        <img
          style="border: solid 3px {{ block.settings.collection_border_color }};"
          src="{{ block.settings.collection_mobile_image | img_url }}"
          alt="{{ block.settings.collection_title }}"
          class="zinara-collection_mobile-image"
        >
        <h3 class="zinara-collection_title">{{ block.settings.collection_title }}</h3>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Home Zinara Collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Zinara Collections"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "text",
          "id": "collection_title",
          "label": "Collection Title"
        },
        {
          "type": "url",
          "id": "collection_link",
          "label": "Collection Link"
        },
        {
          "type": "image_picker",
          "id": "collection_desktop_image",
          "label": "Collection Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "collection_mobile_image",
          "label": "Collection Image"
        },
        {
          "type": "color",
          "id": "collection_border_color",
          "label": "Border Color"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Zinara Collections"
    }
  ]
}
{% endschema %}
